---
import Layout from "../layouts/main.astro"
import { Button } from "../components/ui/button"
import { Separator } from "../components/ui/separator"
import { Mail } from "lucide-react"
---

<Layout>
  <div
    class="mx-auto flex max-w-3xl flex-grow flex-col justify-center px-6 py-12 md:py-16 lg:px-8"
  >
    <section class="flex flex-col">
      <h1
        class="mb-8 text-4xl font-extrabold tracking-tight text-foreground md:text-5xl"
      >
        Hi, I'm Min Pan.
      </h1>
      <p class="mb-8 text-xl leading-relaxed text-foreground/80">
        A passionate frontend developer and designer crafting beautiful,
        high-performance digital experiences with an obsessive attention to
        detail and premium aesthetics.
      </p>
      <article
        class="prose mb-12 max-w-none space-y-6 text-lg leading-relaxed text-foreground/80 prose-zinc dark:prose-invert"
      >
        <p>
          My journey into web development started with a simple fascination for
          how things look and feel on a screen. Over the years, I've cultivated
          a deep appreciation for the intersection of design and engineering. I
          don't just write code; I build interfaces that feel alive, responsive,
          and intuitive.
        </p>
        <p>
          I believe that a great user experience is invisible. It requires
          sweating the small stuff—the micro-interactions, the subtle gradients,
          and the perfect typography.
        </p>
      </article>

      <Separator className="mb-8" />

      <div class="flex items-center justify-start gap-4">
        <Button variant="outline" asChild>
          <a
            href="https://github.com/minpan"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
            GitHub
          </a>
        </Button>
        <Button variant="outline" asChild>
          <a href="mailto:hello@minpan.dev">
            <Mail className="size-4" />
            Email
          </a>
        </Button>
      </div>
    </section>
  </div>
</Layout>
