---
import Layout from "../layouts/main.astro";
---

<Layout>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">
    {/* Intro Header */}
    <section class="flex flex-col md:flex-row gap-12 items-center">
      <div class="flex-grow space-y-6">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
          Hi, I'm <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-accent">Min Pan</span>
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed">
          I am a software engineer, frontend designer, and creator of <a href="/" class="text-foreground font-semibold underline decoration-primary hover:text-primary transition-colors">minpan.dev</a>. I love building high-performance, aesthetically pleasing web experiences that blend engineering precision with premium UI/UX design.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          My work focused on modern frontend frameworks, server-less architectures, and creating responsive web layouts. I enjoy sharing my learning journey through writing articles on modern web design, performance optimization, and developer tools.
        </p>
      </div>
      
      {/* Profile Decorative Card */}
      <div class="relative w-48 h-48 md:w-64 md:h-64 flex-shrink-0">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary to-accent rounded-3xl blur-lg opacity-40 animate-pulse"></div>
        <div class="relative w-full h-full rounded-3xl border border-border/50 bg-card/60 backdrop-blur-md flex items-center justify-center p-6 shadow-xl">
          <div class="text-center space-y-2">
            <span class="text-6xl">👨‍💻</span>
            <div class="font-bold text-lg">Min Pan</div>
            <div class="text-xs text-muted-foreground">Developer & Designer</div>
          </div>
        </div>
      </div>
    </section>

    {/* Skills Section */}
    <section class="space-y-6">
      <h2 class="text-3xl font-bold tracking-tight">My Tech Stack</h2>
      <p class="text-muted-foreground">Here are some of the technologies I work with daily to bring ideas to life:</p>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {[
          { name: "Astro", icon: "🚀", level: "Expert" },
          { name: "React / Next.js", icon: "⚛️", level: "Expert" },
          { name: "TypeScript", icon: "📘", level: "Advanced" },
          { name: "Tailwind CSS", icon: "🎨", level: "Expert" },
          { name: "Node.js", icon: "🟢", level: "Advanced" },
          { name: "PostgreSQL", icon: "🐘", level: "Intermediate" },
          { name: "Git & GitHub", icon: "🐙", level: "Advanced" },
          { name: "UI/UX Design", icon: "📐", level: "Advanced" },
        ].map((skill) => (
          <div key={skill.name} class="p-4 rounded-2xl border border-border/50 bg-card/30 backdrop-blur-sm flex flex-col justify-between hover:border-primary/30 hover:-translate-y-0.5 transition-all">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{skill.icon}</span>
              <div>
                <div class="font-medium text-sm">{skill.name}</div>
                <div class="text-[10px] text-muted-foreground">{skill.level}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Experience / Background */}
    <section class="space-y-6">
      <h2 class="text-3xl font-bold tracking-tight">What I Do</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 rounded-2xl border border-border/50 bg-card/30 backdrop-blur-sm space-y-3">
          <h3 class="text-xl font-bold">Frontend Engineering</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            I specialize in developing responsive, accessible, and fast web applications. I focus on core web vitals, bundle sizes, and leverage modern tools like Tailwind v4, Vite, and Astro to deliver seamless animations and experiences.
          </p>
        </div>
        <div class="p-6 rounded-2xl border border-border/50 bg-card/30 backdrop-blur-sm space-y-3">
          <h3 class="text-xl font-bold">Creative UI/UX Design</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            I believe that great software must feel satisfying to use. I design clean layouts, subtle hover transitions, glassmorphic panels, and curated dark modes to ensure a premium feel across all interfaces.
          </p>
        </div>
      </div>
    </section>

    {/* Contact / Socials */}
    <section class="p-8 rounded-3xl border border-border/50 bg-card/20 backdrop-blur-md text-center space-y-6 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5 -z-10"></div>
      <h2 class="text-3xl font-bold tracking-tight">Let's Connect</h2>
      <p class="text-muted-foreground max-w-lg mx-auto">
        Whether you want to discuss a potential project, ask a question, or just say hello, my inbox is always open.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="mailto:contact@minpan.dev" class="px-6 py-2.5 rounded-xl bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors shadow-md shadow-primary/20">
          Email Me
        </a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 rounded-xl border border-border/50 bg-secondary text-secondary-foreground font-medium hover:bg-secondary/80 transition-all flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          GitHub
        </a>
      </div>
    </section>
  </div>
</Layout>
