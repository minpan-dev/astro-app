---
import PageLayout from "@/layouts/PageLayout.astro"
import { getCollection } from "astro:content"
import ProjectCard from "@/components/ProjectCard.tsx"

const allProjects = await getCollection("projects")
const sortedProjects = allProjects.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)
---

<PageLayout>
  <div class="mx-auto w-full max-w-6xl space-y-12 px-4 py-12 sm:px-6 lg:px-8">
    <div>
      <h1 class="mb-4 text-4xl font-extrabold tracking-tight md:text-5xl">
        我的<span class="text-foreground">项目</span>
      </h1>
      <p class="max-w-2xl text-xl text-muted-foreground">
        我开发的一些前端、后端和全栈项目精选。
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        sortedProjects.map((project) => (
          <ProjectCard
            client:load
            title={project.data.title}
            description={project.data.description}
            date={project.data.publishDate}
            tags={project.data.tags}
            image={project.data.image}
            githubUrl={project.data.githubUrl}
            license={project.data.license}
            status={project.data.status}
            language={project.data.language}
          />
        ))
      }
    </div>
  </div>
</PageLayout>
