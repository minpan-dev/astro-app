---
import Layout from "../../layouts/main.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.tsx";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    <div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        My <span class="text-foreground">Projects</span>
      </h1>
      <p class="text-xl text-muted-foreground max-w-2xl">
        A selection of frontend, backend, and full-stack projects I've built.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedProjects.map((project) => (
        <ProjectCard 
          client:load
          title={project.data.title}
          description={project.data.description}
          date={project.data.publishDate}
          slug={project.id}
          tags={project.data.tags}
          image={project.data.image}
          githubUrl={project.data.githubUrl}
          liveUrl={project.data.liveUrl}
        />
      ))}
    </div>
  </div>
</Layout>
