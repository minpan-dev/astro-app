---
import { getCollection } from "astro:content"
import PostLayout from "@/layouts/PostLayout.astro"

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog")
  blogEntries.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  )

  return blogEntries.map((entry, index) => {
    const prevEntry =
      index + 1 < blogEntries.length ? blogEntries[index + 1] : null
    const nextEntry = index - 1 >= 0 ? blogEntries[index - 1] : null

    return {
      params: { slug: entry.id },
      props: { entry, prevEntry, nextEntry },
    }
  })
}

const { entry, prevEntry, nextEntry } = Astro.props
---

<PostLayout entry={entry} prevEntry={prevEntry} nextEntry={nextEntry} />
