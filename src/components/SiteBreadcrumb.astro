---
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "./ui/breadcrumb"

export interface Props {
  items?: {
    label: string
    href?: string
  }[]
  className?: string
  customTitle?: string
}

const { items: propItems, className, customTitle } = Astro.props

let items: { label: string; href?: string }[] = []

if (propItems) {
  items = propItems
} else {
  const pathname = Astro.url.pathname
  const segments = pathname.split("/").filter(Boolean)

  items = [{ label: "首页", href: "/" }]

  let currentPath = ""
  segments.forEach((segment, index) => {
    currentPath += `/${segment}`
    const isLast = index === segments.length - 1

    const routeNames: Record<string, string> = {
      blog: "博客",
      projects: "项目",
    }

    let label =
      routeNames[segment] ||
      segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, " ")

    // Override the last segment's label with the custom title if provided
    if (isLast && customTitle) {
      label = customTitle
    }

    items.push({
      label,
      href: isLast ? undefined : currentPath,
    })
  })
}
---

<Breadcrumb className={className}>
  <BreadcrumbList>
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1
        return (
          <>
            <BreadcrumbItem>
              {isLast ? (
                <BreadcrumbPage>{item.label}</BreadcrumbPage>
              ) : (
                <BreadcrumbLink href={item.href}>{item.label}</BreadcrumbLink>
              )}
            </BreadcrumbItem>
            {!isLast && <BreadcrumbSeparator />}
          </>
        )
      })
    }
  </BreadcrumbList>
</Breadcrumb>
